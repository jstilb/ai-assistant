#!/bin/bash
# canvas-build — Build Canvas for production and deploy to daemon static directory
# Usage: canvas-build [--native]
#
# Steps:
#   1. Run `tsc -b` in kaya-canvas/
#   2. Run `vite build` in kaya-canvas/
#   3. Copy dist/ to ~/.claude/lib/daemon/static/canvas/
#
# The daemon serves this directory at http://localhost:18000/canvas

set -euo pipefail

CANVAS_DIR="$HOME/Desktop/projects/kaya-canvas"
DAEMON_STATIC_DIR="$HOME/.claude/lib/daemon/static/canvas"

# --- Colors ---
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

# --- Parse args ---
NATIVE=false
for arg in "$@"; do
  case "$arg" in
    --native)
      NATIVE=true
      ;;
    --help|-h)
      echo "Usage: canvas-build [--native]"
      echo ""
      echo "Builds Canvas for production and deploys to the Kaya daemon static directory."
      echo ""
      echo "Options:"
      echo "  --native  Also build the Tauri native macOS app (requires Rust toolchain)"
      echo ""
      echo "Output:"
      echo "  Daemon static dir: $DAEMON_STATIC_DIR"
      echo "  Canvas URL:        http://localhost:18000/canvas"
      exit 0
      ;;
  esac
done

echo -e "${BLUE}Building Canvas for production...${NC}"
echo "  Source: $CANVAS_DIR"
echo ""

# --- 1. TypeScript check (non-blocking: warns but doesn't abort) ---
echo -e "  ${YELLOW}→${NC} TypeScript..."
TS_OUTPUT=$(cd "$CANVAS_DIR" && npx tsc -b 2>&1) || true
TS_ERRORS=$(echo "$TS_OUTPUT" | grep -c "error TS" 2>/dev/null || echo "0")
if [ "$TS_ERRORS" -gt 0 ]; then
  echo -e "  ${YELLOW}!${NC} TypeScript: $TS_ERRORS error(s) — build continues (fix in Tier 1)"
  echo "$TS_OUTPUT" | grep "error TS" | head -5
else
  echo -e "  ${GREEN}✓${NC} TypeScript: OK (0 errors)"
fi

# --- 2. Vite build ---
echo -e "  ${YELLOW}→${NC} Vite build..."
if ! (cd "$CANVAS_DIR" && npx vite build 2>&1); then
  echo -e "  ${RED}✗${NC} Vite build: FAILED"
  exit 1
fi
DIST_DIR="$CANVAS_DIR/dist"
FILE_COUNT=$(find "$DIST_DIR" -type f | wc -l | tr -d ' ')
TOTAL_SIZE=$(du -sh "$DIST_DIR" | cut -f1)
echo -e "  ${GREEN}✓${NC} Vite build: OK ($FILE_COUNT files, $TOTAL_SIZE)"

# --- 3. Deploy to daemon static directory ---
echo -e "  ${YELLOW}→${NC} Deploying to daemon static directory..."
mkdir -p "$DAEMON_STATIC_DIR"
# Remove old files, copy fresh build
rm -rf "${DAEMON_STATIC_DIR:?}"/*
cp -r "$DIST_DIR"/. "$DAEMON_STATIC_DIR/"
echo -e "  ${GREEN}✓${NC} Deploy: Copied to $DAEMON_STATIC_DIR"

# --- 4. Native build (optional, P3) ---
if [ "$NATIVE" = true ]; then
  echo ""
  echo -e "  ${YELLOW}→${NC} Building Tauri native app..."
  if ! command -v cargo >/dev/null 2>&1; then
    echo -e "  ${RED}✗${NC} Rust toolchain not found. Install from https://rustup.rs"
    exit 1
  fi
  if ! (cd "$CANVAS_DIR" && cargo tauri build 2>&1); then
    echo -e "  ${RED}✗${NC} Tauri build: FAILED"
    exit 1
  fi
  echo -e "  ${GREEN}✓${NC} Tauri build: OK"
fi

echo ""
echo -e "${GREEN}Canvas production build ready.${NC}"
echo "  URL: http://localhost:18000/canvas"
echo ""
echo "Start Canvas: canvas-start --production"
