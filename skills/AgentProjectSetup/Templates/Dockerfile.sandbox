# Dockerfile.sandbox - Secure sandbox environment for AI agent execution
# Generated by AgentProjectSetup - DO NOT RUN IN PRODUCTION
#
# Usage:
#   docker build -f Dockerfile.sandbox -t agent-sandbox .
#   docker run --rm -it agent-sandbox
#
# Security Features:
#   - Non-root user execution
#   - Read-only source directory
#   - Resource limits (defined in docker-compose.sandbox.yml)
#   - No-new-privileges security option
#   - Minimal base image

FROM python:3.11-slim AS base

# Security: Create non-root user with restricted shell
RUN useradd -m -s /bin/bash -u 1000 agent && \
    mkdir -p /app /app/output && \
    chown -R agent:agent /app

# Install minimal required packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Set working directory
WORKDIR /app

# Copy requirements first (for caching)
COPY requirements.txt .

# Install dependencies as root (before switching user)
RUN pip install --no-cache-dir -r requirements.txt

# Copy source code
COPY src/ ./src/

# Security: Make source read-only
RUN chmod -R 555 /app/src

# Security: Create output directory with write permissions
RUN mkdir -p /app/output && chown agent:agent /app/output

# Switch to non-root user
USER agent

# Environment variables
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PATH="/home/agent/.local/bin:$PATH"

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import sys; sys.exit(0)" || exit 1

# Default command
CMD ["python", "-m", "src.agent"]

# ---
# For TypeScript/Bun projects, use this alternative:
# ---
# FROM oven/bun:1.0-slim AS base
#
# RUN useradd -m -s /bin/bash -u 1000 agent && \
#     mkdir -p /app /app/output && \
#     chown -R agent:agent /app
#
# WORKDIR /app
#
# COPY package.json bun.lockb ./
# RUN bun install --frozen-lockfile
#
# COPY src/ ./src/
# RUN chmod -R 555 /app/src
#
# USER agent
#
# CMD ["bun", "run", "src/index.ts"]
