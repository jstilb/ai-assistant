  "description": "Cooking recipes with ingredients, instructions, and variations",
  "requiredSections": ["Ingredients", "Instructions"],
  "optionalSections": ["Description", "Prep Notes", "Variations", "Tips", "Nutrition", "Source", "Notes"],
