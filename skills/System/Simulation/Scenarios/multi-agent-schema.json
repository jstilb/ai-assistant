{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multi-Agent Simulation Scenario",
  "description": "JSON Schema for multi-agent simulation scenario configurations. Supports per-agent fault configs, inter-agent dependencies, shared resources, and coordinated execution.",
  "type": "object",
  "required": ["scenario"],
  "properties": {
    "scenario": {
      "type": "object",
      "required": ["id", "name", "description", "type", "target", "environment", "agents", "execution"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Unique scenario identifier"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable scenario name"
        },
        "description": {
          "type": "string",
          "description": "Detailed scenario description"
        },
        "type": {
          "type": "string",
          "enum": ["multi_agent"],
          "description": "Must be 'multi_agent' for multi-agent scenarios"
        },
        "target": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["agent", "workflow", "skill", "hook", "prompt"]
            },
            "skill": { "type": "string" },
            "workflow": { "type": "string" },
            "prompt": { "type": "string" }
          }
        },
        "environment": {
          "type": "object",
          "required": ["sandbox"],
          "properties": {
            "sandbox": {
              "type": "boolean",
              "description": "Whether to use sandbox isolation"
            },
            "copy_skills": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Skills to copy into sandbox"
            },
            "mock_files": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["path", "content"],
                "properties": {
                  "path": { "type": "string" },
                  "content": { "type": "string" }
                }
              }
            }
          }
        },
        "agents": {
          "type": "array",
          "minItems": 1,
          "description": "Array of agent definitions",
          "items": {
            "type": "object",
            "required": ["agent_id", "name", "workload", "fault_config"],
            "properties": {
              "agent_id": {
                "type": "string",
                "minLength": 1,
                "description": "Unique agent identifier within this scenario"
              },
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Human-readable agent name"
              },
              "workload": {
                "type": "string",
                "description": "Task description / prompt for the agent"
              },
              "fault_config": {
                "type": "object",
                "required": ["tool", "mode", "trigger"],
                "description": "Per-agent fault injection configuration",
                "properties": {
                  "tool": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Tool name to intercept"
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["network_timeout", "malformed_response", "rate_limit", "tool_unavailable"],
                    "description": "Type of fault to inject"
                  },
                  "trigger": {
                    "type": "string",
                    "enum": ["call_count", "random_probability", "time_window"],
                    "description": "Trigger condition for fault injection"
                  },
                  "call_count_threshold": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "For call_count trigger: inject on/after this call number"
                  },
                  "probability": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "For random_probability trigger: probability 0-1"
                  },
                  "time_window_start": {
                    "type": "number",
                    "minimum": 0,
                    "description": "For time_window trigger: start time in seconds"
                  },
                  "time_window_end": {
                    "type": "number",
                    "minimum": 0,
                    "description": "For time_window trigger: end time in seconds"
                  },
                  "delay_ms": {
                    "type": "integer",
                    "minimum": 0,
                    "description": "Optional delay in ms for timeout faults"
                  },
                  "message": {
                    "type": "string",
                    "description": "Optional custom fault message"
                  }
                }
              },
              "timeout_ms": {
                "type": "integer",
                "minimum": 1,
                "description": "Per-agent timeout in milliseconds"
              },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Agent IDs that must complete before this agent starts"
              }
            }
          }
        },
        "coordination": {
          "type": "object",
          "description": "Multi-agent coordination settings",
          "properties": {
            "max_parallel": {
              "type": "integer",
              "minimum": 1,
              "default": 4,
              "description": "Maximum number of agents running simultaneously"
            },
            "start_order": {
              "type": "string",
              "enum": ["parallel", "sequential", "staggered"],
              "default": "parallel",
              "description": "How agents are started"
            },
            "stagger_delay_ms": {
              "type": "integer",
              "minimum": 0,
              "default": 1000,
              "description": "Delay between agent starts in staggered mode"
            }
          }
        },
        "shared_state": {
          "type": "object",
          "description": "Initial shared state accessible to all agents",
          "additionalProperties": true
        },
        "shared_resources": {
          "type": "array",
          "description": "Resources shared between agents",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["file", "directory", "state", "transcript"]
              },
              "path": { "type": "string" },
              "access": {
                "type": "string",
                "enum": ["read", "write", "readwrite"],
                "default": "readwrite"
              }
            }
          }
        },
        "cascade_patterns": {
          "type": "array",
          "description": "Cascading fault patterns to apply",
          "items": {
            "type": "object",
            "required": ["name", "steps"],
            "properties": {
              "name": { "type": "string" },
              "steps": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["fault_type", "trigger_after"],
                  "properties": {
                    "fault_type": {
                      "type": "string",
                      "enum": ["network_timeout", "malformed_response", "rate_limit", "tool_unavailable"]
                    },
                    "trigger_after": {
                      "type": "string",
                      "enum": ["immediate", "on_recovery", "on_retry"]
                    },
                    "delay_ms": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "parameters": {
                      "type": "object",
                      "additionalProperties": true
                    }
                  }
                }
              },
              "recovery_check": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "invariants": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "assert"],
            "properties": {
              "name": { "type": "string" },
              "assert": { "type": "string" },
              "params": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "execution": {
          "type": "object",
          "required": ["runs", "timeout_ms"],
          "properties": {
            "runs": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of simulation runs"
            },
            "timeout_ms": {
              "type": "integer",
              "minimum": 1,
              "description": "Global timeout per run in milliseconds"
            },
            "parallel": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of parallel runs"
            },
            "seed": {
              "type": "integer",
              "description": "Random seed for deterministic execution"
            }
          }
        }
      }
    }
  }
}
