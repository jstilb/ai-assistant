{
  "rules": [
    {
      "pattern": "skills/UnixCLI/CLI-INDEX.md",
      "targetLines": 25,
      "preserveKeys": [
        "command names",
        "examples"
      ]
    },
    {
      "pattern": "skills/ContextManager/CONTEXT-INDEX.md",
      "targetLines": 40,
      "preserveKeys": [
        "source names",
        "routing rules",
        "freshness"
      ]
    },
    {
      "pattern": "USER/TELOS/*.md",
      "targetLines": 30,
      "preserveKeys": [
        "mission names",
        "goal IDs",
        "statuses",
        "metrics",
        "dates"
      ]
    },
    {
      "pattern": "context/*.md",
      "targetLines": 50,
      "preserveKeys": [
        "key facts",
        "dates",
        "numbers",
        "statuses"
      ]
    }
  ],
  "minLinesForCompression": 30,
  "outputSuffix": ".compressed.md"
}
