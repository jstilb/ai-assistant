# Kaya Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required: Your Anthropic API key (for Claude Code)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: ElevenLabs API key (for voice server)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Optional: Google API key (for Calendar, Gmail, Sheets)
GOOGLE_API_KEY=your-google-api-key

# Optional: Telegram bot token (for mobile voice interaction)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Optional: Gemini API key (for multi-model inference)
GEMINI_API_KEY=your-gemini-api-key
