# ═══════════════════════════════════════════════════════════════════════════════
# PAI System .gitignore - Private Repository
# ═══════════════════════════════════════════════════════════════════════════════
# This file excludes secrets, credentials, and operational data that should
# never be committed, even to a private repo.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# SECRETS & CREDENTIALS (NEVER COMMIT)
# ─────────────────────────────────────────────────────────────────────────────────
.env
.env.*
.env.local
.env.production
.env.development
*.env

# API Keys & Certificates
*.pem
*.key
*.crt
*.p12
*.pfx
*credential*
*secret*
*_secret*
*-secret*
*.secret
api_key*
apikey*
*token.json
*tokens.json

# PAI Secrets (NEVER COMMIT)
secrets.json

# OAuth & Auth files
oauth*.json
auth*.json
.credentials/
credentials/

# ─────────────────────────────────────────────────────────────────────────────────
# OPERATIONAL DATA (Temporary/Regenerable)
# ─────────────────────────────────────────────────────────────────────────────────
# Logs and debug output
logs/
debug/
*.log
*.log.*

# Shell and session snapshots
shell-snapshots/
session-env/
.current-session

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*.swo
*~
paste-cache/

# Telemetry and monitoring data
telemetry/
statsig/

# Claude Code internal files
tool-results/
projects/*/tool-results/
history.jsonl

# Session-specific todos (ephemeral, regenerated each session)
todos/

# Claude Code session data (ephemeral, regenerated each session)
backups/
file-history/
projects/
plugins/cache/

# ─────────────────────────────────────────────────────────────────────────────────
# EDITOR & OS FILES
# ─────────────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# IDE/Editor
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─────────────────────────────────────────────────────────────────────────────────
# NODE/BUN DEPENDENCIES (Regenerable)
# ─────────────────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.bun/
bun.lockb
bun.lock
**/bun.lock
**/bun.lockb
**/*-bun.lock
*-bun.lock

# ─────────────────────────────────────────────────────────────────────────────────
# LARGE GENERATED FILES
# ─────────────────────────────────────────────────────────────────────────────────
# Bun-compiled bundles (regenerable via bun build)
skills/UnixCLI/Tools/Sheets.js

# Voice server cache (regenerable)
VoiceServer/cache/
VoiceServer/node_modules/

# Observability build artifacts
Observability/*/node_modules/
Observability/*/.next/
Observability/*/dist/

# ─────────────────────────────────────────────────────────────────────────────────
# SETTINGS (Keep base, exclude local overrides)
# ─────────────────────────────────────────────────────────────────────────────────
# settings.json - KEEP (contains identity, not secrets)
# settings.local.json - EXCLUDE (contains session-specific permissions)
settings.local.json

# ─────────────────────────────────────────────────────────────────────────────────
# WORKTREES & NESTED GIT REPOS
# ─────────────────────────────────────────────────────────────────────────────────
# Git worktrees have their own branches — never stage into main
worktrees/

# ─────────────────────────────────────────────────────────────────────────────────
# CACHE FILES (Regenerable)
# ─────────────────────────────────────────────────────────────────────────────────
cache/
.cache/
**/.cache/
*-cache.json
stats-cache.json

# ─────────────────────────────────────────────────────────────────────────────────
# LOCK FILES (Session-specific)
# ─────────────────────────────────────────────────────────────────────────────────
ide/*.lock
tasks/**/.lock

# ─────────────────────────────────────────────────────────────────────────────────
# PLUGINS (Fetched from remote, not source)
# ─────────────────────────────────────────────────────────────────────────────────
plugins/install-counts-cache.json
plugins/installed_plugins.json
plugins/known_marketplaces.json
plugins/marketplaces/

# ─────────────────────────────────────────────────────────────────────────────────
# TRANSIENT STATE
# ─────────────────────────────────────────────────────────────────────────────────
MEMORY/State/current-work.json
MEMORY/State/cache/
MEMORY/VALIDATION/
MEMORY/daemon/cron/*.backup.json

# ─────────────────────────────────────────────────────────────────────────────────
# AUTO-GENERATED PLANS (temp plan mode files with random names)
# ─────────────────────────────────────────────────────────────────────────────────
plans/*-*-*.md

# ─────────────────────────────────────────────────────────────────────────────────
# GENERATED INDEXES & HISTORY
# ─────────────────────────────────────────────────────────────────────────────────
skills/skill-index.json
history/*.jsonl

# ─────────────────════════════════════════════════════════════════════════════════
# WHAT IS TRACKED (For Reference)
# ─────────────────────────────────────────────────────────────────────────────────
# The following ARE tracked for backup/history:
# - skills/           (all skills including _USERCONTEXT, _DTR, _RALPHLOOP)
# - hooks/            (lifecycle handlers)
# - bin/              (maintenance scripts)
# - MEMORY/           (session history, learnings - YOUR BACKUP)
# - context/          (personal context files - YOUR BACKUP)
# - plans/            (planning documents)
# - VoiceServer/      (TTS infrastructure, minus cache)
# - PAISECURITYSYSTEM/ (security patterns)
# - Observability/    (dashboard code, minus builds)
# - settings.json     (identity config - no secrets)
# - CLAUDE.md         (entry point)
# - install.ts        (setup script)
skills/LucidTasks/Data/*.db
skills/LucidTasks/Data/*.db-wal
skills/LucidTasks/Data/*.db-shm

# ─────────────────────────────────────────────────────────────────────────────────
# SCREENSHOTS (Browser automation artifacts, large binaries)
# ─────────────────────────────────────────────────────────────────────────────────
**/screenshots/*.png
